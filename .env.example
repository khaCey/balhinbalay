# Copy to .env and fill in. Server reads .env from project root.

# Database (required for auth, chat, listings)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/balhinbalay

# Push notifications when app is closed (optional)
# 1. Firebase Console → Project settings → Service accounts → Generate new private key
# 2. Save JSON in project root, e.g. firebase-service-account.json (add to .gitignore)
# 3. Uncomment and set:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
